# ==============================================================================
# TESLA DEVELOPER FLEET API CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to `.env` in the same directory:
#   cp .env.example .env
# Then fill in the credentials generated in your developer dashboard.
# ==============================================================================

# Your unique application Client ID from developer.tesla.com
TESLA_CLIENT_ID=your_client_id_here

# Your application Client Secret (required for Fleet API dynamic tokens and refreshing)
TESLA_CLIENT_SECRET=your_client_secret_here

# The custom callback/redirect URI you registered for your app (e.g. http://localhost:8080/callback or https://yourdomain.com/callback)
# Note: For personal CLI scripts, a simple static URL is fine, but you must copy-paste the redirected browser URL when prompted.
TESLA_REDIRECT_URI=your_redirect_uri_here

# OAuth Endpoints (Official Tesla defaults are set below, change only if using custom auth endpoints)
TESLA_AUTH_URL=https://auth.tesla.com/oauth2/v3/authorize
TESLA_TOKEN_URL=https://auth.tesla.com/oauth2/v3/token

# Base endpoint for regional Tesla Fleet API.
# - North America: https://fleet-api.prd.na.vn.cloud.tesla.com/
# - Europe, Middle East, Africa: https://fleet-api.prd.eu.vn.cloud.tesla.com/
# - China: https://fleet-api.prd.cn.vn.cloud.tesla.com/
# Default is 'https://owner-api.teslamotors.com/' for backwards compatibility, but
# Fleet API requires one of the regional endpoints above.
TESLA_BASE_URL=https://fleet-api.prd.na.vn.cloud.tesla.com/

# Optional comma-separated list of scopes.
# Official Fleet API scopes: openid, offline_access, vehicle_device_data, vehicle_cmds, vehicle_charging_cmds
# Defaults to standard ['openid', 'email', 'offline_access'] if left blank.
TESLA_SCOPES=openid,offline_access,vehicle_device_data,vehicle_cmds,vehicle_charging_cmds

# Optional custom directory to save all charge history logs and cache JSON files.
# Defaults to '.' (local directory) if not specified.
# TESLA_DATA_DIR=/path/to/save/logs

